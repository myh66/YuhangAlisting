{
  "name": "alist-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "check": "vue-tsc --noEmit",
    "prebuild": "node scripts/prebuild.js",
    "preview": "vite preview",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri:debug-build": "tauri build --debug --no-bundle --ci",
    "tauri:release": "yarn prebuild --force && tauri build --ci",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@vueuse/core": "^14.3.0",
    "lucide-vue-next": "^1.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
